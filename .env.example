# =====================
# App
# =====================
NODE_ENV=development
PORT=3000

# =====================
# Database
# =====================
MONGODB_URI=mongodb://localhost:27017/strangerconfide

# =====================
# Redis
# =====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =====================
# JWT
# =====================
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this
JWT_REFRESH_EXPIRES_IN=30d

# =====================
# OAuth - Google
# =====================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# =====================
# OAuth - Facebook
# =====================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# =====================
# OTP (tạm thời)
# =====================
# Dev: nhập 000000 để bypass xác thực email. Production: đặt false hoặc bỏ qua.
ALLOW_OTP_BYPASS=true

# =====================
# Email (Nodemailer)
# =====================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=noreply@strangerconfide.com

# =====================
# CORS
# =====================
FRONTEND_URL=http://localhost:3001
# Thêm origin (phân cách bằng dấu phẩy), ví dụ URL ngrok frontend:
# CORS_ORIGINS=https://xxxx.ngrok-free.app
APP_URL=http://localhost:3000

# =====================
# Upload / Storage
# =====================
UPLOAD_DEST=./uploads
MAX_FILE_SIZE_MB=5
