NODE_ENV=production
PORT=3000

# Rate limit & anti-spam (tune theo số user đồng thời)
# ~50 user:  LIMIT_REQUEST=130  MAX_MESSAGES_PER_MINUTE=20  MIN_MESSAGE_INTERVAL_MS=600
# ~100 user: LIMIT_REQUEST=200  MAX_MESSAGES_PER_MINUTE=25  MIN_MESSAGE_INTERVAL_MS=500
# ~300 user: LIMIT_REQUEST=300  MAX_MESSAGES_PER_MINUTE=30  MIN_MESSAGE_INTERVAL_MS=400
LIMIT_REQUEST=200
MAX_MESSAGES_PER_MINUTE=25
MIN_MESSAGE_INTERVAL_MS=500

# Railway: dùng reference hoặc paste URL từ plugin Mongo/Redis
# MONGODB_URI=${{Mongo.MONGO_URL}}
# REDIS_URL=${{Redis.REDIS_URL}}

MONGODB_URI=mongodb://localhost:27017/strangerconfide
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=30d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-app.up.railway.app/api/auth/google/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://your-app.up.railway.app/api/auth/facebook/callback

FRONTEND_URL=https://your-frontend.example.com
CORS_ORIGINS=

UPLOAD_DEST=./uploads
MAX_FILE_SIZE_MB=5

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=StrangerConfide <noreply@example.com>
